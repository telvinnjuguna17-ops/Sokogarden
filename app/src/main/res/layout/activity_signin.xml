<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    android:background="#49C6D3"
    tools:context=".Signin">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="❇️ Signin ❇️"
        android:textSize="38sp"
        android:textAlignment="center"
        android:textStyle="italic|bold"
        android:background="@drawable/shape"
        android:padding="12dp"
        android:fontFamily="cursive"
        android:textColor="#31A64C"/>

<!--    Below is a card view-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="10dp"
        android:padding="10dp">

<!--        Below is a linear layout that align contents vertically-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="10dp">

<!--        Below is the email edit text-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📧 Enter Email Address"
                android:textColorHint="#000"
                android:id="@+id/email"
                android:textColor="#000"
                android:layout_margin="8dp"
                android:background="@color/white"
                android:padding="11dp"/>


<!--            Below is the password edit text&ndash;&gt;-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑 Enter Your Password"
                android:textColorHint="#000"
                android:id="@+id/password"
                android:textColor="#000"
                android:layout_margin="8dp"
                android:background="@color/white"
                android:padding="11dp"/>

<!--            Below is the signin Button-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👮 Signin"
                android:textSize="25sp"
                android:padding="10dp"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:layout_marginTop="8dp"
                android:textColor="#E1CDD8"
                android:backgroundTint="#051232"
                android:id="@+id/signinBtn" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lack an Account? Signup"
                android:textAlignment="center"
                android:textSize="23sp"
                android:layout_marginTop="25dp"
                android:textColor="#000"
                android:id="@+id/signuptxt"/>


        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>